# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=whsec_...

# Supabase Postgres (Prisma)
# The Supabase Vercel integration injects these automatically in deployment.
# POSTGRES_PRISMA_URL = pooled (pgbouncer) connection used at runtime.
# POSTGRES_URL_NON_POOLING = direct connection used for migrations / db push.
POSTGRES_PRISMA_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
POSTGRES_URL_NON_POOLING=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# AgentMail (per-user key is stored in the app; this is optional for local dev)
# AGENTMAIL_API_KEY=...


# Tavily web search (enables the agent's discovery + the search_web MCP tool)
# TAVILY_API_KEY=...

# Apify — one token runs the curated Actors in Discover: Google Maps local
# leads, site contact-detail extraction, and Google search.
# APIFY_TOKEN=apify_api_...

# OpenAI — powers the Scalar agent + vector-memory embeddings
# OPENAI_API_KEY=...
# OPENAI_AGENT_MODEL=gpt-4o   # optional override

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe billing (optional - without these, checkout returns "Billing is not
# configured yet" and the credit meter still runs on plan defaults). Create one
# Product per plan with a recurring (monthly) Price, then paste the price ids
# below. STRIPE_WEBHOOK_SECRET is the signing secret for the webhook endpoint
# you register at /api/webhooks/stripe (events: checkout.session.completed,
# invoice.paid, customer.subscription.deleted).
# STRIPE_SECRET_KEY=sk_live_...        # use sk_test_... in development
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_BUSINESS=price_...

# x402 agent payments (optional). Lets a connected agent pay in USDC over HTTP
# to top up credits (/api/x402/topup) or buy a plan (/api/x402/subscribe).
# Without X402_PAY_TO these endpoints return 501. X402_PAY_TO is the treasury
# wallet that receives USDC. X402_NETWORK is "base" (mainnet, real USDC, needs
# the CDP_API_KEY_* facilitator credentials) or "base-sepolia" (testnet, public
# facilitator, no real money). Defaults to "base".
# X402_PAY_TO=0xYourTreasuryWalletAddress
# X402_NETWORK=base
# CDP_API_KEY_ID=...
# CDP_API_KEY_SECRET=...

# Upstash Redis — durable rate limiting (cross-instance). Without these the
# limiter falls back to a per-instance in-memory limiter (fine for local dev).
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Verified-entity enrichment (free public registries)
# GLEIF (LEI) and SEC EDGAR need no key. Companies House (UK) needs a free key:
COMPANIES_HOUSE_API_KEY=
# SEC requires a descriptive User-Agent; override the default if you like:
SEC_EDGAR_USER_AGENT=

# Email finder -> verifier waterfall (resale-safe; dormant until set).
# Confirm resale rights in writing before enabling for redistribution.
ANYMAILFINDER_API_KEY=
FINDYMAIL_API_KEY=
BOUNCER_API_KEY=

# ── Security secrets (REQUIRED in production) ────────────────────────────────
# OAuth token signing for the MCP server. MUST be a distinct random secret in
# production; without it the code falls back to CLERK_SECRET_KEY, which shares
# one secret across two security contexts. Generate: openssl rand -hex 32
MCP_OAUTH_SECRET=
# Exa webhook auth token (otherwise derived from the OAuth secret).
# EXA_WEBHOOK_SECRET=
# Inngest request signing: required so /api/inngest (a public route) rejects
# forged invocations. Provided by the Inngest dashboard.
INNGEST_SIGNING_KEY=
# Bearer token protecting the provenance re-verify cron route.
CRON_SECRET=
